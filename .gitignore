# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
CLAUDE.md
# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
dist/
bin/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# package manager
package-lock.json
yarn.lock
pnpm-lock.yaml

# semantic-release
.nyc_output

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# flutter
.dart_tool
build
GoogleService-Info.plist

repomix-output.xml
.serena/cache
plans/**/*
!plans/templates/*
screenshots/*
docs/screenshots/*
logs.txt
test-ck
__pycache__

# CK meta commands
prompt.md
ck.md

# Generated runtime layout for release/install smoke tests
/.claude/
# But track repo-level rules that Claude Code reads
!/.claude/rules/

# Local-only state inside tracked claude source
claude/agent-memory/
claude/hooks/.logs/
claude/session-state/latest.md
claude/session-state/archive/
claude/settings.bak.json
claude/skills/ai-multimodal/assets/demo-*.claude/session-state/*.tmp

# Gemini CLI settings (symlink to staged .claude/.mcp.json)
.gemini/settings.json
# Showoff/marketing assets (images, showcases)
assets/
!assets/
!assets/readme/
!assets/readme/**
# Exception: use-mcp ships a persistent tool catalog at assets/tools.json
!claude/skills/use-mcp/assets/
!claude/skills/use-mcp/assets/**

# External repos for study/reference
external/
# Git worktrees (local development only)
worktrees/

AGENTS.md

plans/

.build-release-dmg/

plans/*

docs/

.agents/

.codex/

release-manifest.json

.repomixignore

# Xcode / Swift (KTStack.xcodeproj is generated from project.yml via XcodeGen)
KTStack.xcodeproj/
*.xcworkspace/
xcuserdata/
DerivedData/
*.xcuserstate
.swiftpm/
*.moved-aside
# Binary build scratch (regenerated by scripts/build-*.sh). Vendored output lands in
# KTStack/Resources/bin/ which is already ignored by the `bin/` rule above — those are
# build artifacts produced by the build scripts, not source.
.build-cache/
# Xcode SPM package checkouts + build intermediates (xcodebuild -derivedDataPath .build-xcode)
.build-xcode/
.build-release/
# Spike artifacts — vendored binaries, generated keys/certs, staging (regenerated by run-*.sh)
spikes/**/bin/
spikes/**/caroot/
spikes/**/staging/
spikes/**/staging-MOVED/
spikes/
log/

# Built distributable disk images (use scripts/release/build-dmg.sh)
*.dmg

feature.md


release-*